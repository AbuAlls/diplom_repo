PP_ENV=local
HTTP_ADDR=:8080
CORE_DB_DSN=
ANALYSIS_DB_DSN=
JWT_SECRET=dev-only-secret-change-me
JWT_ISSUER=docsapp
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
MAX_ATTEMPTS=3
WORKER_POLL_INTERVAL=2s
WORKER_BATCH_SIZE=10
STORAGE_ROOT_DIR=/tmp/docsapp-storage
DOWNLOAD_BASE_URL=

# Postgres (внутри docker сети)
DB_HOST=db
DB_PORT=5432
DB_NAME=app
DB_USER=app
DB_PASSWORD=app
DB_SSLMODE=disable

# NATS
NATS_URL=nats://nats:4222

# MinIO (S3)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=app-bucket
S3_USE_SSL=false

# To avoid root-owned files on bind mounts
UID=$(id -u)
GID=$(id -g)
