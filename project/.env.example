PP_ENV=local
HTTP_ADDR=:8080

# Postgres (внутри docker сети)
DB_HOST=db
DB_PORT=5432
DB_NAME=app
DB_USER=app
DB_PASSWORD=app
DB_SSLMODE=disable

# NATS
NATS_URL=nats://nats:4222

# MinIO (S3)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=app-bucket
S3_USE_SSL=false

# To avoid root-owned files on bind mounts
UID=$(id -u)
GID=$(id -g)